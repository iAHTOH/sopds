#!/bin/bash
# Обёртка для конвертации FB2 → EPUB3 через fb2cng (fbc)
LANG=ru_RU.UTF-8
LC_ALL=ru_RU.UTF-8
export LANG
export LC_ALL

run_path=$(dirname "$0")
converter="$run_path/fbc"

if [ ! -x "$converter" ]; then
    echo "ERROR: fb2cng converter not found at $converter" >&2
    exit 1
fi

exec "$converter" convert --to epub3 -o "$2" "$1"
